{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/sheets-api/:path*", "destination": "/api/sheets-proxy?p=:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/checkin-keepalive", "schedule": "0 */2 * * *" }
  ]
}
